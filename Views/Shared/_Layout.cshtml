    <link href="~/Content/dataTables.dataTables.css" rel="stylesheet" />
    <link href="~/Content/dataTables.bootstrap5.min.css" rel="stylesheet" />
    <link href="~/Content/buttons.dataTables.css" rel="stylesheet" />
    <link href="~/Content/uikit.min.css" rel="stylesheet" />
    <link href="~/Content/buttons.dataTables.min.css" rel="stylesheet" />
    <link href="~/Content/dataTables.uikit.css" rel="stylesheet" />
